{
  "name": "service-booking-backend",
  "version": "1.0.0",
  "description": "Backend API for Service Booking Platform",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run prisma:seed"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "5.0.1",
    "dotenv": "16.0.0",
    "express": "4.18.2",
    "jsonwebtoken": "9.0.0",
    "uuid": "9.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.0",
    "@types/express": "4.17.17",
    "@types/jsonwebtoken": "9.0.2",
    "@types/node": "20.0.0",
    "prisma": "^5.22.0",
    "ts-node": "10.9.1",
    "ts-node-dev": "2.0.0",
    "typescript": "^5.9.3"
  }
}
